{
  "host_name": "Northstar Commerce Demo",
  "workspace_target": "#agent-workspace",
  "selectors": {
    "search_input": "#inventory-search",
    "brand_filter": "#location-filter",
    "apply_filters_button": "#apply-filters-btn",
    "refresh_button": "#refresh-inventory-btn",
    "open_buying_guide_button": "#open-maintenance-btn",
    "product_grid": "#inventory-body"
  },
  "supported_actions": [
    "clickSelector",
    "setInputValue",
    "getPageState",
    "getVisibleProducts",
    "getDomTree",
    "renderAgentHtml",
    "appendAgentHtml",
    "fetchDomHtml"
  ],
  "api_files": [
    {
      "name": "DemoCatalogApi",
      "path": "/examples/basic/agent-docs/api-client.js",
      "kind": "javascript-class-reference"
    }
  ],
  "safe_test_prompts": [
    "Summarize the attached host docs, page state, and selectors.",
    "Compare the visible product cards across different brands and render a buying table.",
    "Explain what the demo API exposes and what the visible grid currently shows."
  ]
}
